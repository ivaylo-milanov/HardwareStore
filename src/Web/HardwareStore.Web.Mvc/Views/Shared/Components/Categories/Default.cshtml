@model CategoriesNavModel

@foreach (var group in new (string Title, NavCategoryItem[] Items)[] { ("Peripherals", Model.Peripherals), ("Hardware", Model.Hardware) })
{
    <div class="has-submenu">
        <a>@group.Title</a>
        <div class="submenu">
            @foreach (var category in group.Items)
            {
                <a href="/Product/Index?category=@category.Name&title=@category.Title">@category.Title</a>
            }
        </div>
    </div>
}
