@model ICollection<FavoriteExportModel>

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
        @foreach (var favorite in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 bg-light">
                    <div class="card-body text-center d-flex flex-column py-4 position-relative">
                        <h3 class="h6 card-title mb-2">@favorite.Name</h3>
                        <p class="text-muted mb-3">$@favorite.Price.ToString("F2")</p>
                        <a class="stretched-link" asp-action="Details" asp-controller="Product" asp-route-productId="@favorite.Id" aria-label="View @favorite.Name"></a>
                        <div class="d-flex flex-column gap-2 mt-auto position-relative z-3">
                            <a asp-action="AddToShoppingCart" asp-controller="Cart" asp-route-productId="@favorite.Id" asp-route-quantity="1" class="btn btn-success btn-sm">Buy</a>
                            <form asp-action="RemoveFromFavorite" asp-controller="Favorite" method="post">
                                <input type="hidden" name="productId" value="@favorite.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100">Remove from favorites</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <partial name="_CatalogEmptyProductsMessage" />
}
