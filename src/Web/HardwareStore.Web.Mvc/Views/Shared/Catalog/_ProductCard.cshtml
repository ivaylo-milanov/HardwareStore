@model ProductViewModel

<div class="card h-100 shadow-sm border-0 bg-light">
    <div class="card-body text-center d-flex flex-column py-4 position-relative">
        <h3 class="h6 card-title mb-2">@Model.Name</h3>
        <p class="text-muted mb-3">$@Model.Price.ToString("F2")</p>
        <a class="stretched-link" asp-action="Details" asp-controller="Product" asp-route-productId="@Model.Id" aria-label="View @Model.Name"></a>
        <a asp-action="AddToShoppingCart" asp-controller="Cart" asp-route-productId="@Model.Id" asp-route-quantity="1" class="btn btn-success btn-sm mt-auto align-self-center position-relative z-3">Buy</a>
    </div>
</div>
