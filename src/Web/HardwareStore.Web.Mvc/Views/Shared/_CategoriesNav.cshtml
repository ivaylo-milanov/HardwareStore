@using System.IO
@using System.Text.Json
@using HardwareStore.Common
@inject IWebHostEnvironment HostingEnvironment
@{
    var path = System.IO.Path.Combine(HostingEnvironment.WebRootPath, "data", "categories-nav.json");
    var json = System.IO.File.ReadAllText(path);
    var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
    var nav = JsonSerializer.Deserialize<CategoriesNavModel>(json)
        ?? throw new InvalidOperationException(ExceptionMessages.InvalidCategoriesNavigationJson);
}

@foreach (var group in new (string Title, NavCategoryItem[] Items)[] { ("Peripherals", nav.Peripherals), ("Hardware", nav.Hardware) })
{
    if (group.Items == null || group.Items.Length == 0)
    {
        continue;
    }

    <li class="dropend">
        <a class="dropdown-item dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">@group.Title</a>
        <ul class="dropdown-menu">
            @foreach (var category in group.Items)
            {
                <li>
                    <a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-category="@category.Name" asp-route-title="@category.Title">@category.Title</a>
                </li>
            }
        </ul>
    </li>
}
