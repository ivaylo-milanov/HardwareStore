@model OrderFormModel
@using HardwareStore.Infrastructure.Models.Enums
@{
    var creditSelected = Model.PaymentMethod == PaymentMethod.CreditCard || Model.PaymentMethod == 0;
    var cashSelected = Model.PaymentMethod == PaymentMethod.Cash;
}

<div class="row g-4 justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h2 class="h4 fw-semibold mb-4">Checkout</h2>
                <form id="order-form" asp-action="Place" asp-controller="Checkout" method="post">
                    <h3 class="h6 text-uppercase text-muted mb-3">Personal data</h3>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label" for="FirstName">First name <span class="text-danger">*</span></label>
                            <input type="text" id="FirstName" name="FirstName" class="form-control" required value="@Model.FirstName" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="LastName">Last name <span class="text-danger">*</span></label>
                            <input type="text" id="LastName" name="LastName" class="form-control" required value="@Model.LastName" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="Phone">Phone <span class="text-danger">*</span></label>
                            <input type="text" id="Phone" name="Phone" class="form-control" required value="@Model.Phone" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="Area">Area <span class="text-danger">*</span></label>
                            <input type="text" id="Area" name="Area" class="form-control" required value="@Model.Area" />
                            <span asp-validation-for="Area" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="City">City <span class="text-danger">*</span></label>
                            <input type="text" id="City" name="City" class="form-control" required value="@Model.City" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="Address">Address <span class="text-danger">*</span></label>
                            <input type="text" id="Address" name="Address" class="form-control" required value="@Model.Address" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                    </div>

                    <h3 class="h6 text-uppercase text-muted mb-3">Additional notes</h3>
                    <div class="mb-4">
                        <textarea name="AdditionalNotes" class="form-control" rows="3" placeholder="Delivery instructions (optional)">@Model.AdditionalNotes</textarea>
                    </div>

                    <h3 class="h6 text-uppercase text-muted mb-3">Payment</h3>
                    <div class="d-flex flex-column gap-2 mb-0">
                        <div class="form-check">
                            @if (creditSelected)
                            {
                                <input type="radio" name="PaymentMethod" value="1" id="pm-card" class="form-check-input" checked="checked" />
                            }
                            else
                            {
                                <input type="radio" name="PaymentMethod" value="1" id="pm-card" class="form-check-input" />
                            }
                            <label class="form-check-label" for="pm-card">Credit card</label>
                        </div>
                        <div class="form-check">
                            @if (cashSelected)
                            {
                                <input type="radio" name="PaymentMethod" value="2" id="pm-cash" class="form-check-input" checked="checked" />
                            }
                            else
                            {
                                <input type="radio" name="PaymentMethod" value="2" id="pm-cash" class="form-check-input" />
                            }
                            <label class="form-check-label" for="pm-cash">Cash on delivery</label>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm sticky-lg-top" style="top: 1rem;">
            <div class="card-header bg-success text-white fw-semibold">Order summary</div>
            <div class="card-body">
                <p class="d-flex justify-content-between mb-2"><span class="text-muted">Total</span> <span class="fw-semibold">$@Model.TotalAmount</span></p>
                <p class="text-muted small mb-4">Delivery: free</p>
                <button type="submit" form="order-form" class="btn btn-success w-100 btn-lg">Place order</button>
            </div>
        </div>
    </div>
</div>
