@model ProfileViewModel

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <h1 class="h3 fw-semibold text-center mb-4">Profile</h1>
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">Delivery</div>
            <div class="card-body">
                <p class="mb-1 fw-medium">@Model.FullName</p>
                <p class="text-muted mb-1">@Model.City</p>
                <p class="text-muted mb-0">@Model.Address</p>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light fw-semibold">Contact</div>
            <div class="card-body">
                <p class="mb-0"><a class="link-success text-decoration-none" href="mailto:@Model.Email">@Model.Email</a></p>
            </div>
        </div>
    </div>
</div>
