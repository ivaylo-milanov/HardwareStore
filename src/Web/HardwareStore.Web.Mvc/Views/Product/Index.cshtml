<div class="page-title">
    <h1>@ViewBag.Title</h1>
</div>
<div class="page-body">
    <form class="page-layout" method="get" data-url="@Url.Action("Filter", "Product", new { category = ViewBag.Category })">
        <partial name="_FilterPartialView" model="@ViewBag.Model.Filters as IEnumerable<FilterCategoryModel>"/>
        <partial name="_ProductsContentPartialView" model="@ViewBag.Model.Products as IEnumerable<ProductViewModel>"/>
    </form>
</div>

@section Scripts {
   <script type="module" src="~/js/filter.js"></script>
}