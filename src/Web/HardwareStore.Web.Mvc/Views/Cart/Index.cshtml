@model ShoppingCartViewModel

@if (Model.Shoppings.Any())
{
    <div class="mx-auto" style="max-width: 960px;">
        <h2 class="h3 fw-semibold text-center mb-4">Shopping cart</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" role="alert">
                @Html.ValidationSummary()
            </div>
        }

        <div class="table-responsive shadow-sm rounded mb-4">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Product</th>
                        <th scope="col" class="text-nowrap">Quantity</th>
                        <th scope="col" class="text-end">Price</th>
                        <th scope="col" class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var shopping in Model.Shoppings)
                    {
                        <tr>
                            <td class="fw-medium">@shopping.Name</td>
                            <td>
                                <div class="d-flex flex-wrap align-items-center gap-1">
                                    @if (shopping.Quantity > 1)
                                    {
                                        <form asp-action="DecreaseItemQuantity" asp-controller="Cart" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@shopping.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" aria-label="Decrease quantity">−</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="btn btn-sm btn-outline-secondary disabled opacity-50" aria-disabled="true">−</span>
                                    }
                                    <form asp-action="UpdateItemQuantity" asp-controller="Cart" method="post" class="d-inline-flex align-items-center gap-1">
                                        <input type="hidden" name="ProductId" value="@shopping.ProductId" />
                                        <input type="number" name="Quantity" class="form-control form-control-sm" style="width: 4.5rem;" value="@shopping.Quantity" min="0" max="@shopping.ProductQuantity" aria-label="Quantity" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                                    </form>
                                    <form asp-action="IncreaseItemQuantity" asp-controller="Cart" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@shopping.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" aria-label="Increase quantity">+</button>
                                    </form>
                                    <form asp-action="RemoveFromShoppingCart" asp-controller="Cart" method="post" class="d-inline">
                                        <input type="hidden" name="productId" value="@shopping.ProductId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Remove from cart">×</button>
                                    </form>
                                </div>
                            </td>
                            <td class="text-end text-muted">$@shopping.Price.ToString("F2")</td>
                            <td class="text-end fw-semibold">$@shopping.TotalPrice.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body text-md-end">
                <p class="mb-1 text-muted">Subtotal: <span class="text-dark fw-medium">$@Model.TotalCartPrice.ToString("F2")</span></p>
                <p class="h5 mb-3">Total: <span class="text-success">$@Model.TotalCartPrice.ToString("F2")</span></p>
                @if (Model.TotalCartPrice > 8)
                {
                    <a class="btn btn-success btn-lg" asp-action="Index" asp-controller="Checkout">Checkout</a>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 px-3 mx-auto rounded-3 bg-light border" style="max-width: 480px;">
        <h2 class="h4 mb-3">Your cart is empty</h2>
        <p class="text-muted mb-4">Add products from the catalog to get started.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-success">Start shopping</a>
    </div>
}
