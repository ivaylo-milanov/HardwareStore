@model AdminCustomersIndexViewModel
@{
    ViewData["Title"] = "Customers";
}

<h1 class="h3 fw-semibold mb-3">Customers</h1>
<p class="text-muted small">@Model.TotalCount total · page @Model.Page of @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</p>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">Email</th>
                <th scope="col">Name</th>
                <th scope="col">Admin</th>
                <th scope="col" class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Email</td>
                    <td>@item.FullName</td>
                    <td>@(item.IsAdmin ? "Yes" : "—")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.Items.Count == 0)
{
    <p class="text-muted">No customers found.</p>
}

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Customer pages">
        <ul class="pagination">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)">Previous</a>
            </li>
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
