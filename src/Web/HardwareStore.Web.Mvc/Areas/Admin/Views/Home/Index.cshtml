@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h3 fw-semibold mb-4">Admin dashboard</h1>
<p class="text-muted mb-4">Manage catalog and customer accounts.</p>
<div class="row g-3">
    <div class="col-md-6 col-lg-3">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="card h-100 text-decoration-none text-dark shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Categories</h2>
                <p class="card-text small text-muted mb-0">Create, edit, and remove product categories.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-area="Admin" asp-controller="Manufacturers" asp-action="Index" class="card h-100 text-decoration-none text-dark shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Manufacturers</h2>
                <p class="card-text small text-muted mb-0">Manage manufacturer records.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="card h-100 text-decoration-none text-dark shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Products</h2>
                <p class="card-text small text-muted mb-0">Full product CRUD and options JSON.</p>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-area="Admin" asp-controller="Customers" asp-action="Index" class="card h-100 text-decoration-none text-dark shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Customers</h2>
                <p class="card-text small text-muted mb-0">View accounts, edit profiles, assign Admin role.</p>
            </div>
        </a>
    </div>
</div>
